# Relationship-Engine 配置
# 复制此文件为 .env 并填入你的配置

# 数据存储目录
DATA_DIR=data

# CC Switch 默认 LLM 网关（推荐）
CC_SWITCH_BASE_URL=https://your-ccswitch-url/v1
CC_SWITCH_API_KEY=your-key-here
CC_SWITCH_MODEL=deepseek-chat

# 或者直接用任何 OpenAI 兼容的 LLM
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your-key-here
# LLM_MODEL=deepseek-chat
# LLM_PROVIDER_NAME=DeepSeek

# HTTP 模式配置（远程部署用）
HOST=0.0.0.0
PORT=8080
